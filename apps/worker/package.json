{
  "name": "@hale/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    "./orchestrator": "./src/orchestrator/index.ts",
    "./redaction": "./src/redaction/redact.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "eval:classifier": "node evals/run-eval.mjs --cached-only",
    "eval:drafter": "node evals/run-drafter-eval.mjs --cached-only",
    "eval:memory": "node evals/run-memory-eval.mjs --cached-only",
    "eval:agents": "node evals/run-agent-eval.mjs --cached-only",
    "eval:reviewer": "node evals/run-reviewer-eval.mjs --cached-only",
    "eval:vil143": "node evals/run-vil143-eval.mjs",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "prompts:push": "node scripts/sync-prompts.mjs push",
    "prompts:pull": "node scripts/sync-prompts.mjs pull",
    "prompts:check": "node scripts/sync-prompts.mjs check"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.41.0",
    "@hale/agent": "workspace:*",
    "@hale/db": "workspace:*",
    "@hale/tools-contracts": "workspace:*",
    "@hale/types": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "pg-boss": "^10.1.6",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "resend": "^6.14.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "langfuse": "^3.38.20",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
