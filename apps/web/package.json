{
  "name": "@hale/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "eval:coach": "node evals/run-coach-eval.mjs --cached-only",
    "backfill:source-urls": "tsx scripts/backfill-source-urls.ts",
    "seed:curated-resources": "tsx scripts/seed-curated-resources.ts",
    "clean": "rm -rf .next .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.41.0",
    "@hale/agent": "workspace:*",
    "@hale/db": "workspace:*",
    "@hale/tools-contracts": "workspace:*",
    "@hale/types": "workspace:*",
    "@hale/worker": "workspace:*",
    "@langfuse/otel": "^5.6.0",
    "@langfuse/tracing": "^5.6.0",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@vercel/speed-insights": "^2.0.0",
    "drizzle-orm": "^0.38.3",
    "jose": "^5.10.0",
    "lucide-react": "^1.20.0",
    "next": "^15.1.4",
    "next-auth": "5.0.0-beta.25",
    "pg-boss": "^10.1.6",
    "posthog-js": "^1.393.4",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.14.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
