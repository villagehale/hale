{
  "expo": {
    "name": "Hale",
    "slug": "hale",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hale",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "family.villagehale.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Hale uses the camera to capture milestone photos.",
        "NSMicrophoneUsageDescription": "Hale uses the microphone for voice — asking and logging by speaking.",
        "NSSpeechRecognitionUsageDescription": "Hale transcribes your voice to text."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#021E4E",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-speech-recognition"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
