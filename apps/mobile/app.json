{
  "expo": {
    "name": "Hale",
    "slug": "hale-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hale",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "family.villagehale.app",
      "buildNumber": "15",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleDisplayName": "Hale",
        "NSCameraUsageDescription": "Hale uses the camera to capture milestone photos.",
        "NSMicrophoneUsageDescription": "Hale uses the microphone for voice \u2014 asking and logging by speaking.",
        "NSSpeechRecognitionUsageDescription": "Hale transcribes your voice to text.",
        "NSPhotoLibraryUsageDescription": "Hale accesses your photo library so you can add photos to your child's milestones and memories.",
        "NSLocationWhenInUseUsageDescription": "Hale uses your approximate location once to find your village area. Your exact location never leaves your phone.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B2160",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-speech-recognition",
      "expo-apple-authentication",
      [
        "expo-maps",
        {
          "requestLocationPermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f8eba851-1254-4fba-8320-a517eeef7434"
      },
      "apiBase": "https://app.villagehale.com",
      "google": {
        "iosClientId": "65507972660-aqt1spng7qnphkt3oe50dkqs5gumn67r.apps.googleusercontent.com"
      }
    },
    "owner": "villagehale"
  }
}
