{
  "name": "hale",
  "version": "0.0.1",
  "private": true,
  "description": "Passive multi-agent household AI assistant for families, across every stage of childhood (0\u201318)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "lint:fix": "biome lint --apply .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "eval:agents": "pnpm --filter @hale/worker eval:agents",
    "eval:vil143": "pnpm --filter @hale/worker eval:vil143",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:generate": "pnpm --filter @hale/db generate",
    "db:migrate": "pnpm --filter @hale/db migrate",
    "db:studio": "pnpm --filter @hale/db studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "@expo/dom-webview": "56.0.6"
    }
  }
}
