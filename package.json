{
  "name": "hale",
  "version": "0.0.1",
  "private": true,
  "description": "Passive multi-agent household AI assistant for families, across every stage of childhood (0–18)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "lint:fix": "biome lint --apply .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:generate": "pnpm --filter @hale/db generate",
    "db:migrate": "pnpm --filter @hale/db migrate",
    "db:studio": "pnpm --filter @hale/db studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
