{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm turbo build --filter=@hale/web",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "outputDirectory": "apps/web/.next",
  "regions": ["yyz1"],
  "github": {
    "silent": true
  },
  "crons": [
    { "path": "/api/cron/digest", "schedule": "0 12 * * *" },
    { "path": "/api/cron/inference", "schedule": "0 6 * * *" },
    { "path": "/api/cron/discovery", "schedule": "0 13 * * 1" }
  ]
}
