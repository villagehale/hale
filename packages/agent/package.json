{
  "name": "@hale/agent",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "skills:seed": "node scripts/check-skills.mjs seed",
    "skills:check": "node scripts/check-skills.mjs check"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.41.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
