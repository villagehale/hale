# ─── App URLs ─────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
WORKER_URL=http://localhost:4000

# ─── Database (Postgres / Supabase Toronto) ───────────────────────────────
# Pooled connection (use in app runtime)
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres
# Direct connection (use for migrations only)
DATABASE_DIRECT_URL=postgresql://postgres:password@localhost:54322/postgres

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Langfuse (prompt management + tracing) ───────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Integrations: Google (Gmail + Calendar + Photos) ─────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/haru-gmail-watch

# ─── Integrations: Microsoft (Outlook + Calendar) ─────────────────────────
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Twilio (SMS) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Email (Postmark) ─────────────────────────────────────────────────────
POSTMARK_API_KEY=
POSTMARK_FROM_ADDRESS=hello@haru.family

# ─── Encryption (column-level envelope encryption) ────────────────────────
# 32-byte base64-encoded key; rotate quarterly
APP_ENCRYPTION_KEY=

# ─── Observability ────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Internal service-to-service auth ─────────────────────────────────────
INTERNAL_API_SHARED_SECRET=
