# ─── App URLs ─────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
WORKER_URL=http://localhost:4000

# ─── Database (Postgres / Supabase Toronto) ───────────────────────────────
# Pooled connection (use in app runtime)
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres
# Direct connection (use for migrations only)
DATABASE_DIRECT_URL=postgresql://postgres:password@localhost:54322/postgres

# ─── Auth (Auth.js / NextAuth v5 — Google OAuth) ──────────────────────────
# Secret used to sign the session JWT (e.g. `openssl rand -base64 33`).
AUTH_SECRET=
# Google OAuth credentials (also used for Gmail/Calendar integrations below).
# Authorized redirect URI: <APP_URL>/api/auth/callback/google
# GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET are set in the Google section below.

# ─── Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Langfuse (prompt management + tracing) ───────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Integrations: Google (Gmail + Calendar + Photos) ─────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/hale-gmail-watch

# Closed-beta invite gate. While BETA_INVITE_ONLY is on (anything but "false"),
# /onboarding requires ?invite=<BETA_INVITE_CODE> (or a prior invite cookie);
# everyone else is sent to the marketing waitlist. Public launch = set
# BETA_INVITE_ONLY=false (one switch). Invite link: <APP_URL>/onboarding?invite=<code>
BETA_INVITE_ONLY=true
BETA_INVITE_CODE=
NEXT_PUBLIC_MARKETING_URL=https://villagehale.com

# ─── Integrations: Microsoft (Outlook + Calendar) ─────────────────────────
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Twilio (SMS) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=hello@villagehale.com
# Master switch for sending the daily-brief email. Off unless set to exactly
# 'true' — composing + storing the brief is unaffected; only the outbound send is
# gated. Keep OFF until the sending domain is verified, then flip deliberately.
DIGEST_SEND_ENABLED=false
# Signs CASL one-click unsubscribe links (HMAC). Without it, briefs are NOT sent
# (no compliant unsubscribe link can be minted). Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=

# ─── Scheduled agents (Vercel Cron) ───────────────────────────────────────
# Shared secret the cron routes (apps/web/app/api/cron/*) require as
# `Authorization: Bearer <CRON_SECRET>`. Vercel injects it automatically on cron
# invocations; without a match the route 401s and does no work (no spend).
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Encryption (column-level envelope encryption) ────────────────────────
# 32-byte base64-encoded key; rotate quarterly
APP_ENCRYPTION_KEY=

# ─── Observability ────────────────────────────────────────────────────────
# Error tracking, privacy-first. Absent DSN = clean no-op (no init, no network).
# SENTRY_DSN gates the server/edge SDK; NEXT_PUBLIC_SENTRY_DSN gates the browser
# SDK. Exceptions only — no tracing, no session replay, no PII (child data).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
# Monthly Anthropic spend (sum of agent_runs.cost_usd) above which the
# /api/cron/spend-alert route raises an alert. Defaults to 200 when unset.
ANTHROPIC_SPEND_ALERT_USD=200

# ─── Product analytics (PostHog) ──────────────────────────────────────────
# Client-side, privacy-first. Absent key = clean no-op (autocapture off, session
# replay off, DNT respected, no PII/child data — only coarse key-loop events,
# identified by opaque user id). Set both in apps/web AND apps/site.
# HOST picks the region: https://us.i.posthog.com or https://eu.i.posthog.com.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Internal service-to-service auth ─────────────────────────────────────
INTERNAL_API_SHARED_SECRET=
